# ─── Secrets (NEVER commit these) ───────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ─── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ─── Virtual Environments ───────────────────────────────────
venv/
env/
.venv/
ENV/

# ─── Data & Models (too large for git) ──────────────────────
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
*.pkl
*.bin
*.pt
*.ckpt
models/

# ─── Databases ──────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─── IDE ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ─── Testing & Coverage ─────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log

# ─── Docker ─────────────────────────────────────────────────
# Keep Dockerfiles, ignore generated volumes
docker-volumes/

# ─── Node (for frontend later) ──────────────────────────────
node_modules/
.next/
