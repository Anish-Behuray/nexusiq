# ============================================================
# NexusIQ Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It's in .gitignore.
# ============================================================

# ─── LLM Providers ──────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Used for re-ranking in Phase 2. Get from: https://cohere.com
COHERE_API_KEY=...

# ─── Vector Database (Weaviate) ─────────────────────────────
# For local Docker: use http://localhost:8080
# For Weaviate Cloud: https://your-cluster.weaviate.network
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=                   # Leave empty for local dev

# ─── Application Settings ───────────────────────────────────
APP_NAME=NexusIQ
APP_ENV=development                 # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# ─── Backend API ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Database (PostgreSQL) ──────────────────────────────────
# For Phase 1, SQLite is used. PostgreSQL config for Phase 2+.
DATABASE_URL=sqlite:///./nexusiq.db
# DATABASE_URL=postgresql://user:password@localhost:5432/nexusiq

# ─── Security ───────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── LangSmith (Observability) ──────────────────────────────
# Get from: https://smith.langchain.com — enables agent tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=nexusiq-dev

# ─── RAG Settings ───────────────────────────────────────────
# Model used for generating embeddings
EMBEDDING_MODEL=text-embedding-3-small

# LLM used for reasoning (main agent model)
LLM_MODEL=gpt-4o-mini              # Use gpt-4o for production

# How many chunks to retrieve before re-ranking
RETRIEVAL_TOP_K=10

# Final chunks passed to LLM after re-ranking
RERANK_TOP_K=5

# ─── Ingestion Settings ─────────────────────────────────────
# Max characters per chunk (tune based on your embedding model)
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Path to your local documents for ingestion
DOCS_DIR=./data/raw
